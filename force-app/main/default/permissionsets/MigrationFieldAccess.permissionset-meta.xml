<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Migration Field Access</label>
    <description>Read+Edit on MigrationID__c (Account/Contact/Opportunity/Task). Assign
        directly -- profile-name-based FLS grants miss non-standard admin
        profiles (e.g. "Modified Admin User" on OrgFarm orgs). See hard rule 8.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <fieldPermissions>
        <field>Account.MigrationID__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Contact.MigrationID__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Opportunity.MigrationID__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Task.MigrationID__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
</PermissionSet>
