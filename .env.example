# ---------------------------------------------------------------------------
# Salesforce auth. Pick ONE mode.
#   cli      -> reuse an org you've already authed with `sf org login web`
#               (fastest; no secrets stored in this repo)
#   jwt      -> connected-app JWT bearer flow (production / CI, no browser)
#   password -> username + password + security token (dev fallback)
# ---------------------------------------------------------------------------
SF_AUTH_MODE=cli
SF_API_VERSION=67.0

# cli mode: the alias/username you passed to `sf org login web --alias ...`
SF_ORG_ALIAS=MIGRATION_TARGET

# jwt mode
SF_USERNAME=
SF_CONSUMER_KEY=
SF_PRIVATE_KEY_FILE=./server.key
SF_DOMAIN=login          # login = prod/dev edition, test = sandbox

# password mode
SF_PASSWORD=
SF_SECURITY_TOKEN=

# ---------------------------------------------------------------------------
# SQL backend -- "mssql" (default), "sqlite", or "postgresql" (roadmap #69).
# Only the section matching your chosen backend below actually applies.
# ---------------------------------------------------------------------------
SQL_BACKEND=mssql

# SQL Server (your integration hub, sql_backend == "mssql")
SQL_SERVER=localhost
SQL_DATABASE=SF_Migration
SQL_DRIVER=ODBC Driver 18 for SQL Server
SQL_TRUSTED_CONNECTION=yes   # yes = Windows auth; no = use SQL_UID / SQL_PWD
SQL_UID=
SQL_PWD=
SQL_ENCRYPT=yes
SQL_TRUST_SERVER_CERT=yes    # yes for local dev (Driver 18 encrypts by default)

# PostgreSQL (sql_backend == "postgresql") -- reuses SQL_SERVER/SQL_DATABASE/
# SQL_UID/SQL_PWD above for host/database/user/password; these two are the
# only genuinely Postgres-specific settings.
SQL_PORT=5432
SQL_POSTGRES_SSLMODE=prefer  # disable/allow/prefer/require/verify-ca/verify-full

# Local staging dir for CSV round-trips (kept out of git)
STAGE_DIR=./_stage

# ---------------------------------------------------------------------------
# Mockaroo (mock/demo data generation) -- https://mockaroo.com/account (API key)
# Free tier: 200 requests/day, up to 5,000 records/request.
# ---------------------------------------------------------------------------
MOCKAROO_API_KEY=

# ---------------------------------------------------------------------------
# Migration Run Book (roadmap #16) -- link to this project's ticket-system project
# shown in the Migration Run Book's header. Not a credential -- override per-project
# with generate-migration-run-book/add-migration-run-book-pass's --ticket-url/--ticket-label.
# ---------------------------------------------------------------------------
TICKET_SYSTEM_LABEL=JIRA
TICKET_SYSTEM_URL=

# ---------------------------------------------------------------------------
# Docker Compose local dev environment (roadmap #68/#69, docs/DOCKER.md) --
# only read by docker-compose.yml itself (the sqlserver/postgres/app-*
# services), never by the Python app directly. Only needed if you're
# using `docker compose` instead of a host-installed SQL Server/Postgres.
#
# COMPOSE_PROFILES picks which backend's services actually start --
# Compose reads this the same way it reads every other ${VAR}
# substitution below, so a plain `docker compose up -d` with no
# --profile flag still works exactly like before this setting existed.
# Set to "postgres" instead to bring up the postgres/app-postgres pair.
# ---------------------------------------------------------------------------
COMPOSE_PROFILES=mssql

# mssql profile -- SQL Server requires a strong password: 8+ characters,
# with upper+lower+digit+symbol.
MSSQL_SA_PASSWORD=

# postgres profile -- POSTGRES_USER/PASSWORD are this container's own
# credentials, separate from SQL_UID/SQL_PWD above (which a host venv
# might use for an entirely different real Postgres server elsewhere).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
