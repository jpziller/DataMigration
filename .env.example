# ---------------------------------------------------------------------------
# Salesforce auth. Pick ONE mode.
#   cli      -> reuse an org you've already authed with `sf org login web`
#               (fastest; no secrets stored in this repo)
#   jwt      -> connected-app JWT bearer flow (production / CI, no browser)
#   password -> username + password + security token (dev fallback)
# ---------------------------------------------------------------------------
SF_AUTH_MODE=cli
SF_API_VERSION=67.0

# cli mode: the alias/username you passed to `sf org login web --alias ...`
SF_ORG_ALIAS=MIGRATION_TARGET

# jwt mode
SF_USERNAME=
SF_CONSUMER_KEY=
SF_PRIVATE_KEY_FILE=./server.key
SF_DOMAIN=login          # login = prod/dev edition, test = sandbox

# password mode
SF_PASSWORD=
SF_SECURITY_TOKEN=

# ---------------------------------------------------------------------------
# SQL Server (your integration hub)
# ---------------------------------------------------------------------------
SQL_SERVER=localhost
SQL_DATABASE=SF_Migration
SQL_DRIVER=ODBC Driver 18 for SQL Server
SQL_TRUSTED_CONNECTION=yes   # yes = Windows auth; no = use SQL_UID / SQL_PWD
SQL_UID=
SQL_PWD=
SQL_ENCRYPT=yes
SQL_TRUST_SERVER_CERT=yes    # yes for local dev (Driver 18 encrypts by default)

# Local staging dir for CSV round-trips (kept out of git)
STAGE_DIR=./_stage

# ---------------------------------------------------------------------------
# Mockaroo (mock/demo data generation) -- https://mockaroo.com/account (API key)
# Free tier: 200 requests/day, up to 5,000 records/request.
# ---------------------------------------------------------------------------
MOCKAROO_API_KEY=
