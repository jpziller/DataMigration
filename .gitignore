.env
.venv/
_stage/
_sqlite/
__pycache__/
*.pyc
server.key
server.crt
*.log
.mcp.json
.claude/settings.local.json

# Generated, org-specific artifacts -- every org's schema/mappings differ,
# so these aren't template content. Commit your own deliberately if a real
# engagement wants a versioned copy (see README's "Repository structure").
metadata/*.json
mapping/*.xlsx
!metadata/.gitkeep
!mapping/.gitkeep

# Deliberate exception: the NPSP-to-NPC migration proof-of-concept's own
# mapping workbooks ARE the versioned copy this repo wants -- a real
# reference implementation for a future NPSP->NPC engagement, not
# disposable single-project output. See okf/npsp-to-npc/reference-implementation.md.
!mapping/npc_*.xlsx

# Local `sf` CLI source-tracking state, per-org, per-machine -- not project source.
.sf/
